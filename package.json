{
  "name": "@willh/copilot-ralph",
  "version": "0.3.2",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "copilot-ralph": "dist/cli-entry.js"
  },
  "scripts": {
    "bump": "npm version patch --no-git-tag-version && npm install --package-lock-only",
    "build": "bun x tsc -p tsconfig.json && bun run scripts/copy-assets.mjs && bun run scripts/inject-version.mjs",
    "postinstall": "node scripts/ensure-vscode-jsonrpc-node-shim.mjs",
    "dev": "tsx src/cli-entry.ts",
    "test": "bun x vitest run",
    "test:watch": "bun x vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ms": "^2.1.3",
    "vscode-jsonrpc": "^8.2.1"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.19.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^4.0.16"
  }
}
